# ── Copy this to .env and fill in real values before running ──────────────────
# Never commit .env to version control

# MongoDB
MONGO_INITDB_ROOT_USERNAME=energyadmin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGO_DB=energy_monitor

# API Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_PYTHON_SECRETS_TO_GENERATE_THIS
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Email (for password reset + verification — optional in dev)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.XXXX
# FROM_EMAIL=noreply@yourdomain.com
